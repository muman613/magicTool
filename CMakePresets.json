      "displayName": "Host Debug",
      "description": "Configure only the Qt5 host library and host applications in debug mode",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "DEBUG_TOOL_BUILD_FIRMWARE": "OFF",
