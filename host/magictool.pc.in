prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@MAGICTOOL_INSTALL_LIBDIR@
includedir=${prefix}/@MAGICTOOL_INSTALL_INCLUDEDIR@

Name: magictool
Description: Qt5 host library for the debug_tool Pico firmware
Version: @PROJECT_VERSION@
Requires.private: Qt5Core Qt5SerialPort
Libs: -L${libdir} -lmagictool
Cflags: -I${includedir}
